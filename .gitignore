# ==========================================
# AetherOS — Next.js .gitignore
# ==========================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---- Next.js build output ----
.next/
out/

# ---- Production build ----
build/
dist/

# ---- Environment variables ----
# Never commit secrets to version control
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# ---- Vercel deployment ----
.vercel

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- OS / System files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Editor & IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---- Coverage & Testing ----
coverage/
.nyc_output/
*.lcov

# ---- Misc ----
*.pem
.cache/
.temp/
.tmp/
